---
const { posts = [] } = Astro.props;
---

<div class="blog-grid">
	{
		posts.map((post) => {
			const slug = post.id.replace(/\.(md|mdx)$/, '');

			return (
				<article class="blog-card">
					<a href={`/blog/${slug}/`} class="blog-card__link">
						{post.data.heroImage && (
							<div class="blog-card__image">
								<img
									src={post.data.heroImage}
									alt={post.data.title}
									loading="lazy"
								/>
							</div>
						)}

						<div class="blog-card__content">
							{post.data.category ? (
								<span class="badge badge--blog blog-card__category">
									{post.data.category}
								</span>
							) : null}

							<h3 class="blog-card__title">{post.data.title}</h3>
							<p class="blog-card__desc">{post.data.description}</p>

							<div class="blog-card__meta">
								<time datetime={post.data.pubDate.toISOString()}>
									📅 {post.data.pubDate.toLocaleDateString('es-PY')}
								</time>
								<span class="blog-card__read">Leer más →</span>
							</div>
						</div>
					</a>
				</article>
			);
		})
	}
</div>
